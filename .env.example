# ──────────────────────────────────────────────────────────────
# Demo access
# ──────────────────────────────────────────────────────────────
DEMO_PASSCODE=appraise
APP_URL=https://YOUR-SITE.netlify.app

# Set DEMO_FAKE=1 to run entirely offline (no DocuSign, no DB, no Blobs).
# In fake mode all DocuSign vars below are ignored.
# See README for the netlify dev / Vite-only caveat before using this flag.
DEMO_FAKE=

# ──────────────────────────────────────────────────────────────
# DocuSign developer sandbox — JWT Server-Side Grant
# https://developers.docusign.com/platform/auth/jwt-get-token/
# ──────────────────────────────────────────────────────────────
DS_BASE_PATH=https://demo.docusign.net/restapi
DS_OAUTH_BASE_PATH=account-d.docusign.com

# From Apps and Keys → Integration Key (Client ID)
DS_INTEGRATION_KEY=

# From Apps and Keys → API Username (your user GUID, not your email)
DS_USER_ID=

# From your sandbox account → Account ID
DS_ACCOUNT_ID=

# RSA private key PEM generated in Apps and Keys.
# In Netlify env vars, paste the full PEM value; the loader converts literal \n.
# Locally you can point to a file path, or set the multi-line value in .env.
DS_PRIVATE_KEY=

# Email address of the user who granted JWT consent (used by the spike script)
DS_SPIKE_EMAIL=

# ──────────────────────────────────────────────────────────────
# Database
# NETLIFY_DATABASE_URL is injected automatically by `netlify db init`.
# Do NOT set this by hand — let Netlify provision and manage it.
# ──────────────────────────────────────────────────────────────
